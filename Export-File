-- 3.3 VALIDIERUNG DER TRIGGER-LOGIK (FUNKTIONSTESTS)
-- -----------------------------------------------------------------------------

-- Rücksetzung Testdatensatz order_id = 6
DELETE FROM payment WHERE order_id = 6;
UPDATE orders SET status = 'created_at' WHERE order_id = 6;

-- a) INSERT: Beim Anlegen einer Zahlung wird der Status der Bestellung automatisch auf paid_at gesetzt.
INSERT INTO payment(order_id, amount, payment_method, status) VALUES (6, 100.00, 'paypal', 'paid_at');
SELECT order_id, status FROM orders WHERE order_id = 6;

-- b) INSERT: Beim Anlegen einer Zahlung wird den Status der Bestellung automatisch auf paid_at gesetzt.
DELETE FROM payment WHERE order_id = 6; 
INSERT INTO payment(order_id, amount, payment_method, status) VALUES (6, 100.00, 'paypal', 'refunded_at');
SELECT order_id, status FROM orders WHERE order_id = 6;

-- c) UPDATE: Die Zahlung hat sich auf pending_at geändert und die Bestellung wird daraufhin zurück auf created_at gesetzt.
UPDATE payment SET status = 'pending_at' WHERE order_id = 6;
SELECT order_id, status FROM orders WHERE order_id = 6;

-- d) UPDATE: Eine nachträgliche Änderung des Zahlungsstatus auf paid_at bestätigt, dass auch die Bestellung korrekt auf paid_at überführt wurde.
UPDATE payment SET status = 'paid_at' WHERE order_id = 6;
SELECT order_id, status FROM orders WHERE order_id = 6;


