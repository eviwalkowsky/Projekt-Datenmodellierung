-- -----------------------------------------------------------------------------
-- 3.1 REFACTORING (SCHEMA-MIGRATION & ENUM-ANPASSUNG)
-- -----------------------------------------------------------------------------
-- Hinweis: Updates erfolgen vor der Trigger-Erstellung zur Vermeidung von Overhead

-- Refactoring Tabelle 'orders'
ALTER TABLE orders ADD COLUMN status_new VARCHAR(20);
UPDATE orders SET status_new=CASE status
    WHEN 'created' THEN 'created_at'
    WHEN 'paid' THEN 'paid_at'
    WHEN 'shipped' THEN 'shipped_at'
    WHEN 'delivered' THEN 'delivered_at'
    WHEN 'cancelled' THEN 'cancelled_at'
END;
ALTER TABLE orders DROP COLUMN status;
ALTER TABLE orders CHANGE COLUMN status_new status
ENUM('created_at','paid_at','shipped_at','delivered_at','cancelled_at') NOT NULL DEFAULT 'created_at';

-- Refactoring Tabelle 'payment'
ALTER TABLE payment ADD COLUMN status_new VARCHAR(20);
UPDATE payment SET status_new=CASE status
    WHEN 'pending' THEN 'pending_at'
    WHEN 'paid' THEN 'paid_at'
    WHEN 'failed' THEN 'failed_at'
    WHEN 'refunded' THEN 'refunded_at'
END;
ALTER TABLE payment DROP COLUMN status;
ALTER TABLE payment CHANGE COLUMN status_new status
ENUM('pending_at','paid_at','failed_at','refunded_at') NOT NULL DEFAULT 'pending_at';

-- View-Anpassung nach ENUM-Änderung
CREATE OR REPLACE VIEW view_order_status_report AS
SELECT status AS Bestellstatus, COUNT(*) AS Anzahl_Bestellungen
FROM orders
GROUP BY status
ORDER BY FIELD(status,'created_at','paid_at','shipped_at','delivered_at','cancelled_at');


-- -----------------------------------------------------------------------------
-- 3.2 TRIGGER-IMPLEMENTIERUNG (PROZESS-AUTOMATISIERUNG)
-- -----------------------------------------------------------------------------
DELIMITER //

CREATE TRIGGER after_payment_insert
AFTER INSERT ON payment
FOR EACH ROW
BEGIN
    IF NEW.status = 'pending_at' THEN
        UPDATE orders SET status = 'created_at' WHERE order_id = NEW.order_id;
    ELSEIF NEW.status = 'paid_at' THEN
        UPDATE orders SET status = 'paid_at' WHERE order_id = NEW.order_id;
    ELSEIF NEW.status = 'failed_at' THEN
        UPDATE orders SET status = 'created_at' WHERE order_id = NEW.order_id;
    ELSEIF NEW.status = 'refunded_at' THEN
        UPDATE orders SET status = 'cancelled_at' WHERE order_id = NEW.order_id;
    END IF;
END;
//

DELIMITER ;

DELIMITER //

CREATE TRIGGER after_payment_update
AFTER UPDATE ON payment
FOR EACH ROW
BEGIN
    IF OLD.status <> NEW.status THEN
        IF NEW.status = 'pending_at' THEN
            UPDATE orders SET status = 'created_at' WHERE order_id = NEW.order_id;
        ELSEIF NEW.status = 'paid_at' THEN
            UPDATE orders SET status = 'paid_at' WHERE order_id = NEW.order_id;
        ELSEIF NEW.status = 'failed_at' THEN
            UPDATE orders SET status = 'created_at' WHERE order_id = NEW.order_id;
        ELSEIF NEW.status = 'refunded_at' THEN
            UPDATE orders SET status = 'cancelled_at' WHERE order_id = NEW.order_id;
        END IF;
    END IF;
END;
//

DELIMITER ;


